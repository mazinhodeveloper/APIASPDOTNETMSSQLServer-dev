<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - API ASP.NET Core</title>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>
    <header>
        <nav>
            <a href="/">Home</a> |
            <a href="/acl">ACL</a>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <p>&copy; @DateTime.Now.Year - API ASP.NET Core</p>
    </footer>

    <script src="~/js/scripts.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>